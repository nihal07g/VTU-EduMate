# VTU EduMate Environment Variables

# Gemini AI API Key (required for AI features)
GEMINI_API_KEY=your_gemini_api_key_here
NEXT_PUBLIC_GEMINI_API_KEY=your_gemini_api_key_here

# MongoDB Connection (required for database operations)
MONGODB_URI=mongodb://localhost:27017/vtu-edumate

# Next.js URL (for production)
NEXTAUTH_URL=http://localhost:3000

# Google Drive API (optional, for advanced integration)
GOOGLE_DRIVE_API_KEY=your_google_drive_api_key
GOOGLE_CLIENT_ID=your_google_client_id

# Add your API keys and configuration here
